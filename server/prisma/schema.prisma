// Wedding Management System — Prisma schema
//
// NOTE ON ARCHITECTURE:
// All runtime DB access goes through PostgreSQL stored procedures in the
// `wedding` schema (see prisma/seed-procedures.sql). The service layer only
// uses prisma.$queryRaw to call those procedures — never prisma.model.*.
//
// This schema file exists so `prisma generate` can produce a typed client and
// to document the data model. The single source of truth for DDL + procedures
// is prisma/seed-procedures.sql. Run that file instead of `prisma migrate`
// (the SQL script is idempotent and also creates the stored procedures).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["wedding"]
}

enum FamilyType {
  CHULEY
  SINGLE

  @@map("family_type_enum")
  @@schema("wedding")
}

enum Side {
  BRIDE
  GROOM
  BOTH

  @@map("side_enum")
  @@schema("wedding")
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED

  @@map("rsvp_status_enum")
  @@schema("wedding")
}

enum GiftType {
  CASH
  KIND

  @@map("gift_type_enum")
  @@schema("wedding")
}

enum EventCategory {
  CEREMONY
  RECEPTION
  RITUAL
  MEAL
  ENTERTAINMENT
  OTHER

  @@map("event_category_enum")
  @@schema("wedding")
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID

  @@map("payment_status_enum")
  @@schema("wedding")
}

model Guest {
  id             String     @id @default(uuid()) @db.Uuid
  familyName     String     @map("family_name")
  familyType     FamilyType @map("family_type")
  side           Side
  attendeeCount  Int        @map("attendee_count")
  confirmedCount Int?       @map("confirmed_count")
  contactPhone   String?    @map("contact_phone")
  address        String?
  remarks        String?
  rsvpStatus     RsvpStatus @default(PENDING) @map("rsvp_status")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(6)

  gifts Gift[]

  @@map("guests")
  @@schema("wedding")
}

model Gift {
  id          String    @id @default(uuid()) @db.Uuid
  guestId     String    @map("guest_id") @db.Uuid
  giftType    GiftType  @map("gift_type")
  amount      Decimal?  @db.Decimal(12, 2)
  description String?
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  remarks     String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  guest Guest @relation(fields: [guestId], references: [id])

  @@map("gifts")
  @@schema("wedding")
}

model ItineraryEvent {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  eventDate   DateTime      @map("event_date") @db.Date
  startTime   String        @map("start_time")
  endTime     String?       @map("end_time")
  location    String?
  responsible String?
  category    EventCategory @default(OTHER)
  orderIndex  Int           @default(0) @map("order_index")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)

  @@map("itinerary_events")
  @@schema("wedding")
}

model CostItem {
  id            String        @id @default(uuid()) @db.Uuid
  category      String
  itemName      String        @map("item_name")
  estimatedCost Decimal       @map("estimated_cost") @db.Decimal(12, 2)
  actualCost    Decimal?      @map("actual_cost") @db.Decimal(12, 2)
  vendor        String?
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  @@map("cost_items")
  @@schema("wedding")
}
