# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding_db
PORT=4000
NODE_ENV=development

# --- CORS (frontend origin; comma-separated; wildcards like https://*.vercel.app allowed) ---
CORS_ORIGIN=http://localhost:5173

# --- Frontend base URL (used in OTP/invite email links) ---
APP_URL=http://localhost:5173

# --- JWT (required in production; dev has fallbacks) ---
ACCESS_TOKEN_SECRET=replace_with_32+_char_random_string
REFRESH_TOKEN_SECRET=replace_with_another_32+_char_random_string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# --- SMTP (optional; if unset, OTP/invite emails are logged to the server console) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Wedding App <your@gmail.com>
